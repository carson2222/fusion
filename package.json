{
  "name": "@carson2222/fusion",
  "version": "0.1.0",
  "description": "Fan a hard prompt out to a panel of models in parallel as read-only explorers, then aggregate their findings into one answer. An OpenCode plugin.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "command",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "fusion",
    "multi-model",
    "llm",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carson2222/fusion.git"
  },
  "homepage": "https://github.com/carson2222/fusion#readme",
  "bugs": "https://github.com/carson2222/fusion/issues",
  "author": "Carson (https://github.com/carson2222)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@opencode-ai/sdk": "latest",
    "typescript": "^5.6.0"
  }
}
